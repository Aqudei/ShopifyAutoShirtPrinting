<UserControl x:Class="ShopifyEasyShirtPrinting.Views.OrderProcessingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:converters="clr-namespace:ShopifyEasyShirtPrinting.Converters"
             xmlns:behaviors="clr-namespace:ShopifyEasyShirtPrinting.Behaviours"
             mah:DialogParticipation.Register="{Binding}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="1366"
             Background="{DynamicResource MahApps.Brushes.ThemeBackground}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:DictionaryToVisibilityConverter x:Key="DictionaryToVisibilityConverter" />
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
        <BitmapImage x:Key="LoaderImage" UriSource="/Resources/unknwon.png" />
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="380" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <FrameworkElement x:Name="DummyElement" Visibility="Collapsed"/>

        <Border Grid.Row="0" Grid.Column="0" Background="{DynamicResource MahApps.Brushes.Gray10}" Padding="12" CornerRadius="4" Margin="0,0,12,12">
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Command="{Binding GenerateQrCommand}" Style="{StaticResource MahApps.Styles.Button.Flat}" ToolTip="Print QR Tags" Margin="0,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="QrcodeScan" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Print QR Tags" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SaveQrTagsCommand}" Style="{StaticResource MahApps.Styles.Button.Flat}" ToolTip="Save QR Tag/s" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ContentSave" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Save QR Tags" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Border Width="1" Height="22" Background="{DynamicResource MahApps.Brushes.Gray8}" Margin="8,2"/>
                    <Button Command="{Binding PrintCommand}" CommandParameter="+" Style="{StaticResource MahApps.Styles.Button.Flat}" ToolTip="Print Incremental (+)" Margin="8,0,4,0">
                        <iconPacks:PackIconMaterial Kind="Printer" Foreground="#4CAF50"/>
                    </Button>
                    <Button Command="{Binding PrintCommand}" CommandParameter="-" Style="{StaticResource MahApps.Styles.Button.Flat}" ToolTip="Print Decremental (-)" Margin="0,0,4,0">
                        <iconPacks:PackIconMaterial Kind="Printer" Foreground="#F44336"/>
                    </Button>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                        <ComboBox x:Name="comboBox" Width="180" ItemsSource="{Binding Tags}" SelectedValuePath="Key" DisplayMemberPath="Value"
                                  mah:TextBoxHelper.Watermark="Mark Order As..." mah:TextBoxHelper.UseFloatingWatermark="True"/>
                        <Button Command="{Binding ApplyTagCommand}" CommandParameter="{Binding SelectedValue, ElementName=comboBox}" 
                                Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Width="60" Margin="4,0,0,0" ToolTip="Apply Tag Change">
                            <iconPacks:PackIconMaterial Kind="Check" Foreground="White"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ComboBox x:Name="comboBoxStatus" Width="180" IsReadOnly="True" ItemsSource="{Binding Tags}" 
                                  SelectedValue="{Binding SelectedTagFilter}" SelectedValuePath="Key" DisplayMemberPath="Value"
                                  IsEnabled="{Binding IsFilterEnabled}" mah:TextBoxHelper.Watermark="Filter By Status..." mah:TextBoxHelper.UseFloatingWatermark="True"/>
                        <Button Command="{Binding ClearStatusFilterCommand}" IsEnabled="{Binding IsFilterEnabled}"
                                Style="{StaticResource MahApps.Styles.Button.Square}" Width="60" Margin="4,0,0,0" ToolTip="Clear Filter Selection">
                            <iconPacks:PackIconMaterial Kind="FilterRemove"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,12,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding CheckHighlightedCommand}" CommandParameter="{Binding SelectedItems, ElementName=OrdersDataGrid}" ToolTip="Check Highlighted Row Items" Style="{StaticResource MahApps.Styles.Button.Chromeless}" Padding="6">
                    <iconPacks:PackIconMaterial Kind="CheckboxMultipleMarked" Foreground="#2196F3" Height="18" Width="18"/>
                </Button>
                <Button Grid.Column="1" Command="{Binding UncheckHighlightedCommand}" CommandParameter="{Binding SelectedItems, ElementName=OrdersDataGrid}" ToolTip="Uncheck Highlighted Row Items" Style="{StaticResource MahApps.Styles.Button.Chromeless}" Padding="6" Margin="4,0,0,0">
                    <iconPacks:PackIconMaterial Kind="CheckboxMultipleBlankOutline" Foreground="#757575" Height="18" Width="18"/>
                </Button>
                <Button Grid.Column="2" Command="{Binding RefreshCommand}" ToolTip="Refresh Active Dataset" Style="{StaticResource MahApps.Styles.Button.Chromeless}" Padding="6" Margin="12,0,0,0">
                    <iconPacks:PackIconMaterial Kind="Refresh" Foreground="#4CAF50" Height="18" Width="18"/>
                </Button>
                <Button Grid.Column="3" Command="{Binding CrudCommand}" CommandParameter="Create" ToolTip="Add New Manifest Entry" Style="{StaticResource MahApps.Styles.Button.Chromeless}" Padding="6" Margin="4,0,0,0">
                    <iconPacks:PackIconMaterial Kind="PlusBox" Foreground="#009688" Height="18" Width="18"/>
                </Button>
                <Button Grid.Column="4" Command="{Binding CrudCommand}" CommandParameter="Update" ToolTip="Edit Highlighted Product Metadata" Style="{StaticResource MahApps.Styles.Button.Chromeless}" Padding="6" Margin="4,0,0,0">
                    <iconPacks:PackIconMaterial Kind="SquareEditOutline" Foreground="#FF9800" Height="18" Width="18"/>
                </Button>

                <TextBox Grid.Column="5" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         mah:TextBoxHelper.Watermark="Search structural records..." mah:TextBoxHelper.ClearTextButton="True"
                         FontSize="14" VerticalContentAlignment="Center" Margin="16,0,0,0" Padding="4"/>
            </Grid>

            <DataGrid x:Name="OrdersDataGrid" Grid.Row="1" ItemsSource="{Binding LineItemsView}" SelectedItem="{Binding SelectedLineItem, Mode=TwoWay}"
                      FontSize="14" IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                      FrozenColumnCount="2" IsSynchronizedWithCurrentItem="True" SelectionMode="Extended"
                      mah:ScrollViewerHelper.IsHorizontalScrollWheelEnabled="True" ScrollViewer.CanContentScroll="True"
                      Style="{StaticResource MahApps.Styles.DataGrid}">
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource MahApps.Styles.DataGridCell}">
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="Padding" Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent3}" />
                                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Text}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource MahApps.Styles.DataGridRow}">
                        <Setter Property="Background" Value="{Binding Path=Status, Converter={StaticResource StatusToColorConverter}}" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Gray8}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="Auto" CanUserSort="False">
                        <DataGridTemplateColumn.Header>
                            <CheckBox IsChecked="{Binding DataContext.MasterCheckBoxState, ElementName=OrdersDataGrid, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Command="{Binding DataContext.CheckBoxCommand, ElementName=OrdersDataGrid}"
                                      CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Margin="4,0"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Order No." Binding="{Binding OrderNumber}" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" />
                    <DataGridTextColumn Header="Printed" Binding="{Binding PrintedQuantity}"/>

                    <DataGridTemplateColumn Header="Name" SortMemberPath="Name" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="NoteTextOutline" Visibility="{Binding HasNotes, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="130"
                                        Visibility="{Binding DataContext.ColumnVisibility, Converter={StaticResource DictionaryToVisibilityConverter}, ConverterParameter='Sku', Source={x:Reference DummyElement}, Mode=OneWay}"/>

                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" />
                    <DataGridTextColumn Header="Shipping" Binding="{Binding Shipping}" Width="120"/>
                    <DataGridTextColumn Header="Bin Location" Binding="{Binding BinNumber}" FontWeight="SemiBold"/>
                    <DataGridTextColumn Header="Date Modified" Binding="{Binding DateModifiedLocal}" />

                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MahApps.Styles.TextBlock}">
                                <Setter Property="TextWrapping" Value="Wrap" />
                                <Setter Property="MaxHeight" Value="36"/>
                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Customer" Binding="{Binding Customer}" Width="140"/>
                    <DataGridTextColumn Header="Customer Email" Binding="{Binding CustomerEmail}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="2" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,4">
                    <iconPacks:PackIconMaterial Kind="InformationOutline" Width="14" Height="14" VerticalAlignment="Center" Margin="2,0,6,0" Foreground="{DynamicResource MahApps.Brushes.Gray3}"/>
                    <TextBlock FontSize="12" Foreground="{DynamicResource MahApps.Brushes.Gray3}">
                        <Run Text="Showing " />
                        <Run Text="{Binding TotalDisplayed, Mode=OneWay}" FontWeight="SemiBold" />
                        <Run Text=" of " />
                        <Run Text="{Binding TotalItems, Mode=OneWay}" />
                        <Run Text=" items (" />
                        <Run Text="{Binding TotalSelected, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                        <Run Text=" selected)" />
                    </TextBlock>
                </StackPanel>

                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Notes}" TextWrapping="Wrap" Height="65" VerticalScrollBarVisibility="Auto"
                         mah:TextBoxHelper.Watermark="Append operational notes to currently highlighted batch sequence entries..." Padding="6"/>
                <Button Grid.Row="1" Grid.Column="1" Command="{Binding ApplyNotesCommand}" Style="{StaticResource MahApps.Styles.Button.Square.Accent}" Margin="6,0,0,0" Width="120">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="NotePlus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Apply Notes" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <Grid Grid.Row="0" Grid.Column="1" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="340" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Variant Image Mapping Preview" Style="{StaticResource MahApps.Styles.GroupBox}" Margin="0,0,0,12">
                <Border BorderBrush="{DynamicResource MahApps.Brushes.GridLines}" BorderThickness="1" Background="{DynamicResource MahApps.Brushes.ThemeBackground}" CornerRadius="2">
                    <Image Margin="8" Source="{Binding CurrentImage, Mode=OneWay, TargetNullValue={StaticResource LoaderImage}}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>
            </GroupBox>

            <Border Grid.Row="1" Background="{DynamicResource MahApps.Brushes.Gray10}" Padding="12" CornerRadius="4" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding DetectedQr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="NoWrap" MaxLines="1"
                             mah:TextBoxHelper.Watermark="Scan item barcode pipeline..." mah:TextBoxHelper.ClearTextButton="True" FontSize="14" VerticalContentAlignment="Center" Padding="4"/>
                    <Button Grid.Row="0" Grid.Column="1" Command="{Binding BrowseQrCommand}" Style="{StaticResource MahApps.Styles.Button.Square}" Width="40" Margin="4,0,0,0" ToolTip="Browse Local QR File...">
                        <iconPacks:PackIconMaterial Kind="QrcodeScan" Height="16" Width="16"/>
                    </Button>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <TextBlock Text="Scan Mode:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12" Foreground="{DynamicResource MahApps.Brushes.Text}"/>
                        <ComboBox Width="160" SelectedItem="{Binding SelectedScanMode}" ItemsSource="{Binding ScanModes}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" BorderBrush="{DynamicResource MahApps.Brushes.GridLines}" BorderThickness="1" CornerRadius="4">
                <TabControl Style="{StaticResource MahApps.Styles.TabControl}">
                    <TabItem Header="Order Parameters">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="8">
                            <ItemsControl ItemsSource="{Binding ScanInfo}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MahApps.Brushes.Gray9}" Padding="0,6">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Key, Mode=OneTime}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                                                <TextBlock Text="{Binding Value, Mode=OneTime}" FontSize="13" Margin="4,2,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Audit History Log">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="8">
                            <ItemsControl ItemsSource="{Binding Logs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MahApps.Brushes.Gray9}" Padding="0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ChangeDateLocal, Mode=OneWay, StringFormat={}{0:MM/dd HH:mm}}" FontSize="12" Foreground="{DynamicResource MahApps.Brushes.Gray3}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ChangeStatus}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>
    </Grid>
</UserControl>