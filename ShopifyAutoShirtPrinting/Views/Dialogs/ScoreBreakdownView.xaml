<UserControl x:Class="ShopifyEasyShirtPrinting.Views.Dialogs.ScoreBreakdownView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:ico="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="900">

    <Grid Background="{DynamicResource MahApps.Brushes.ThemeBackground}">

        <Border Padding="20"
                Margin="10"
                CornerRadius="12"
                Background="{DynamicResource MahApps.Brushes.Control.Background}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Orientation="Horizontal">

                    <ico:PackIconMaterial Width="28"
                                          Height="28"
                                          VerticalAlignment="Center"
                                          Kind="ClipboardTextOutline"
                                          Foreground="{DynamicResource MahApps.Brushes.Accent}" />

                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Text="Score Breakdown" />

                </StackPanel>

                <!-- LIST -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto">

                    <ItemsControl ItemsSource="{Binding ScoreBreakdowns}">

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border Margin="0,0,0,18"
                                        Padding="18"
                                        CornerRadius="10"
                                        Background="{DynamicResource MahApps.Brushes.Gray2}">

                                    <Grid>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="14"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- FIELD -->
                                        <StackPanel>

                                            <TextBlock FontSize="12"
                                                       FontWeight="Bold"
                                                       Opacity="0.7"
                                                       Text="FIELD" />

                                            <DockPanel Margin="0,6,0,0">

                                                <ico:PackIconMaterial Width="18"
                                                                      Height="18"
                                                                      Margin="0,0,8,0"
                                                                      VerticalAlignment="Center"
                                                                      Kind="TextBoxOutline"
                                                                      Foreground="{DynamicResource MahApps.Brushes.Accent}" />

                                                <TextBlock VerticalAlignment="Center"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Field}" />

                                            </DockPanel>

                                        </StackPanel>

                                        <!-- ISSUES -->
                                        <StackPanel Grid.Row="2">

                                            <TextBlock FontSize="12"
                                                       FontWeight="Bold"
                                                       Opacity="0.7"
                                                       Text="ISSUES" />

                                            <Border Margin="0,6,0,0"
                                                    Padding="10"
                                                    CornerRadius="8"
                                                    Background="{DynamicResource MahApps.Brushes.Control.Background}">

                                                <ItemsControl ItemsSource="{Binding Issues}">

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>

                                                            <Border Margin="0,4"
                                                                    Padding="10"
                                                                    CornerRadius="6"
                                                                    Background="#22FF6B6B">

                                                                <DockPanel>

                                                                    <ico:PackIconMaterial Width="18"
                                                                                          Height="18"
                                                                                          Margin="0,0,8,0"
                                                                                          VerticalAlignment="Center"
                                                                                          Kind="AlertCircleOutline"
                                                                                          Foreground="#FF6B6B" />

                                                                    <TextBlock VerticalAlignment="Center"
                                                                               TextWrapping="Wrap"
                                                                               Text="{Binding}" />

                                                                </DockPanel>

                                                            </Border>

                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>

                                                </ItemsControl>

                                            </Border>

                                        </StackPanel>

                                        <!-- DETAILS -->
                                        <StackPanel Grid.Row="4">

                                            <TextBlock FontSize="12"
                                                       FontWeight="Bold"
                                                       Opacity="0.7"
                                                       Text="DETAILS" />

                                            <DataGrid Margin="0,6,0,0"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      HeadersVisibility="Column"
                                                      IsReadOnly="True"
                                                      ItemsSource="{Binding Details}">

                                                <DataGrid.Columns>

                                                    <DataGridTextColumn Header="Key"
                                                                        Width="2*"
                                                                        Binding="{Binding Key}" />

                                                    <DataGridTextColumn Header="Value"
                                                                        Width="3*"
                                                                        Binding="{Binding Value}" />

                                                </DataGrid.Columns>

                                            </DataGrid>

                                        </StackPanel>

                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                    </ItemsControl>

                </ScrollViewer>

            </Grid>

        </Border>

    </Grid>
</UserControl>