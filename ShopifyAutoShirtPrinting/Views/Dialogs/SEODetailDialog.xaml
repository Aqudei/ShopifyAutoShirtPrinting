<UserControl x:Class="ShopifyEasyShirtPrinting.Views.Dialogs.SEODetailDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShopifyEasyShirtPrinting.Views.Dialogs"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="700">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F3F3F3" Padding="10" CornerRadius="4" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding Handle}" FontSize="18" FontWeight="Bold" Foreground="#333"/>
                    <TextBlock Text="{Binding PageType}" FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Grade, StringFormat='Grade: {0}'}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding Score, StringFormat='Score: {0:F1}'}" FontSize="12" Foreground="#555" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Grid.IsSharedSizeScope="True">

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Target Keyword:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding TargetKeyword, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="SEO Title:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding SEOTitle, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Meta Description:" VerticalAlignment="Top" Margin="0,4,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding MetaDescription, UpdateSourceTrigger=PropertyChanged}" 
                             MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                </Grid>

                <Separator Margin="0,15"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Description HTML:" VerticalAlignment="Top" Margin="0,4,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding DescriptionHtml, UpdateSourceTrigger=PropertyChanged}" 
                             MinHeight="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                </Grid>

                <Separator Margin="0,15"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelGroup"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Image Alt Text:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Text="{Binding ImageAltText, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Save &amp; Close" 
            Command="{Binding SaveAndCloseCommand}" 
            Width="100" 
            Margin="0,0,10,0" />

            <Button Content="Cancel" 
            Command="{Binding CancelCommand}" 
            Width="100"/>
        </StackPanel>
    </Grid>
</UserControl>