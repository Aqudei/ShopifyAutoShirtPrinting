<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <OutputType>WinExe</OutputType>
    <AssemblyName>ShopifyEasyShirtPrinting</AssemblyName>
    <RootNamespace>ShopifyEasyShirtPrinting</RootNamespace>
    <StartupObject>ShopifyEasyShirtPrinting.App</StartupObject>
    <LangVersion>latest</LangVersion>
    <PlatformTarget>x64</PlatformTarget>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <!-- Keep desktop compatibility: enable Windows-specific features and app manifest handling -->
    <UseWindowsForms>false</UseWindowsForms>
  </PropertyGroup>

  <!-- Reference to upgraded Common project -->
  <ItemGroup>
    <ProjectReference Include="..\\Common\\Common.csproj" />
  </ItemGroup>

