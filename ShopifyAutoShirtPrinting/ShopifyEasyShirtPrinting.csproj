    <Compile Remove="Api\ShipStation\ShipStationApi.cs" />
    <Compile Remove="Data\DbService.cs" />
    <Compile Remove="Data\ILineRepository.cs" />
    <Compile Remove="Data\IOrderRepository.cs" />
