    <PackageReference Include="Prism.Wpf" Version="9.0.537" />
    <PackageReference Include="EPPlus" Version="8.6.1" />
    <PackageReference Include="Magick.NET-Q16-AnyCPU" Version="14.14.0" />
    <PackageReference Include="AutoMapper" Version="16.1.1" />
    <PackageReference Include="AngleSharp" Version="1.5.1" />
    <PackageReference Include="RabbitMQ.Client" Version="7.2.1" />
    <PackageReference Include="SharpZipLib" Version="1.4.2" />
    <PackageReference Include="ShopifySharp" Version="6.28.0" />
    <PackageReference Include="Sprache" Version="2.3.1" />
    <PackageReference Include="Microsoft.Xaml.Behaviors.Wpf" Version="1.1.142" />
    <!-- PdfiumViewer is not net10-compatible; keep as net472-only reference via Common or conditionally add later -->
  </ItemGroup>

